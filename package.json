{
  "name": "dnd-pet-project",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev": "cd apps/multiverse-front && npx vite --host --port 3000",
    "build": "cd apps/multiverse-front && tsc -b && npx vite build",
    "lint": "cd apps/multiverse-front && npx eslint .",
    "prepare": "husky",
    "preview": "cd apps/multiverse-front && npx vite preview --port 3000",
    "storybook": "cd apps/multiverse-front && npx storybook dev -p 6006",
    "build-storybook": "cd apps/multiverse-front && npx storybook build",
    "nx:graph": "nx graph"
  },
  "dependencies": {
    "lucide-react": "^1.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^0.11.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "nx": "22.7.5",
    "playwright": "^1.60.0",
    "sass-embedded": "^1.100.0",
    "storybook": "^10.4.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-checker": "^0.14.1",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx eslint --fix",
      "npx prettier --write"
    ],
    "*.{js,jsx,cjs,mjs,json,css,scss,md}": [
      "npx prettier --write"
    ]
  },
  "nx": {}
}
